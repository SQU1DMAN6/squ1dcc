var numCells = array.cat(brain)
io.echo("The brain has:", numCells, "cells.\n")

var tumorCount = 0
var normalCount = 0
var inc = 0

while (inc < numCells) {
    if (brain[inc] == "normal") {
        normalCount = normalCount + 1
    } el {
        tumorCount = tumorCount + 1
    }

    inc = inc + 1
}

io.echo("There are", tumorCount, "tumors and", normalCount, "normal cells.\n")

var tumorCountFl = type.i2fl(tumorCount)
var normalCountFl = type.i2fl(normalCount)

var ratio = divide.divideTwoNumbers(tumorCountFl, normalCountFl)
io.echo("The tumor-to-normal ratio is:", ratio, "\n")

var selectedCell = io.read("Select a cell: ")
var cellType = brain[selectedCell]

io.write("The selected cell", selectedCell, "is a", cellType)
