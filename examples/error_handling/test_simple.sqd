test >> (arr, index) {
    if (index >= len(arr)) {
        return {
            "ok": false,
            "value": null,
            "error": "Out of bounds"
        }
    }
    
    return {
        "ok": true,
        "value": arr[index],
        "error": null
    }
}

var arr = [10, 20, 30]
var result = test(arr, 1)
io.echo("Done\n")
