# ============================================================================
# SQU1DLANG ERROR HANDLING STANDARD
# ============================================================================
# All fallible functions return: { "ok": boolean, "value": any, "error": str|null }
# ============================================================================

# Example 1: Divide function
divide >> (a, b) {
    if (b == 0) {
        return {
            "ok": false,
            "value": null,
            "error": "Division by zero"
        }
    }

    return {
        "ok": true,
        "value": {
            "quotient": a / b,
            "remainder": a % b
        },
        "error": null
    }
}

# Example 2: Parse integer function
parseInt >> (str) {
    var result = type.s2i(str)
    
    if (type.tp(result) == "Error") {
        return {
            "ok": false,
            "value": null,
            "error": result
        }
    }
    
    return {
        "ok": true,
        "value": result,
        "error": null
    }
}

# ============================================================================
# METHOD 1: UNSAFE - DO NOT USE
# ============================================================================

io.echo("=== METHOD 1 ===\n")

if ((<< divide(51, 3)) == null) {
    io.echo("OK\n")
}

io.echo("Done\n")
