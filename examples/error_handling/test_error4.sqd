# ============================================================================
# Example 3: Safe array access
safeArrayGet >> (arr, index) {
    if (type.tp(arr) != "Array") {
        return {
            "ok": false,
            "value": null,
            "error": "Input must be an Array"
        }
    }
    
    if (index < 0) {
        return {
            "ok": false,
            "value": null,
            "error": "Index cannot be negative"
        }
    }
    
    if (index >= len(arr)) {
        return {
            "ok": false,
            "value": null,
            "error": "Index out of bounds"
        }
    }
    
    return {
        "ok": true,
        "value": arr[index],
        "error": null
    }
}

io.echo("Test\n")
