safeArrayGet >> (arr, index) {
    if (type.tp(arr) != "Array") {
        return {
            "ok": false,
            "value": null,
            "error": "Input must be an Array"
        }
    }
    
    if (index < 0) {
        return {
            "ok": false,
            "value": null,
            "error": "Index cannot be negative"
        }
    }
    
    if (index >= len(arr)) {
        return {
            "ok": false,
            "value": null,
            "error": "Index out of bounds"
        }
    }
    
    return {
        "ok": true,
        "value": arr[index],
        "error": null
    }
}

io.echo("TEST: ARRAY ACCESS SUCCESS\n")

var arr = [10, 20, 30, 40]
var getResult = safeArrayGet(arr, 2)

if (getResult.ok) {
    io.echo("Success!\n")
    io.echo(getResult.value)
    io.echo("\n")
} el {
    io.echo("Error: ")
    io.echo(getResult.error)
    io.echo("\n")
}
